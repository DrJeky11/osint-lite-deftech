{
  "name": "osint-lite-deftech",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "refresh:rss": "node ./scripts/refresh-rss.mjs",
    "refresh:bluesky": "node ./scripts/refresh-bluesky.mjs",
    "refresh:live": "npm run refresh:rss && npm run refresh:bluesky",
    "generate:data": "node ./scripts/generate-data.mjs",
    "build": "npm run generate:data && vite build",
    "build:live": "npm run refresh:live && npm run build",
    "preview": "vite preview",
    "test": "node --test",
    "dev": "vite --host 0.0.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "svelte": "^5.55.4",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "circle-flags": "^2.8.2",
    "maplibre-gl": "^5.23.0"
  }
}
